# Server-side only (used by local Express server — NOT exposed to browser)
ANTHROPIC_API_KEY=sk-ant-...

# Frontend env vars (prefixed with VITE_ — these ARE visible in the browser, so NO secrets here)
VITE_WORKER_URL=https://converter-api.YOUR_SUBDOMAIN.workers.dev
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
